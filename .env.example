# Spatial Workbench — environment variables
# Copy to .env and fill in as needed.

# (Optional) OpenAI API key — used as fallback when users don't provide their own.
# OPENAI_API_KEY=sk-...

# Local Ollama base URL used by the server when public users do not supply one.
# Defaults to http://localhost:11434
# OLLAMA_BASE_URL=http://localhost:11434

# Server port (default: 3000)
# PORT=3000

# Comma-separated allowed origins for CORS (leave blank for open CORS in dev).
# CORS_ORIGINS=https://danmaps.github.io,https://workbench.dannymcvey.com
