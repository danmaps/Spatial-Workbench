  "main": "js/app.js",
  "scripts": {
    "test": "jest",
    "test:headless": "npm test -- --runInBand js/headless-runtime.test.js server.headless.test.js",
    "test:mcp": "npm test -- --runInBand mcp-server.test.js",
    "start": "nodemon server.js",
    "start:prod": "node server.js",
    "build": "webpack",
    "build:prod": "webpack --config webpack.prod.config.js",
    "watch": "webpack --watch",
    "demo:headless": "node scripts/headless-demo.js",
    "mcp:server": "node scripts/mcp-server.js",
    "validate:headless-artifact": "node scripts/validate-headless-artifact.js",
    "spec:update": "node scripts/generate_specs.js && node scripts/generate_tool_docs.js",
    "spec:check": "node scripts/generate_specs.js --check",
    "docs:update": "node scripts/generate_tool_docs.js"
  },
  "jest": {
    "testEnvironment": "jsdom"
  },
  "author": "",
