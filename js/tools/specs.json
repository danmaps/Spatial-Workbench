[
  {
    "key": "AddDataTool",
    "name": "Add Data",
    "description": "Upload GeoJSON or tabular data (CSV/XLSX) with coordinates",
    "headlessSupported": false,
    "parameters": [
      {
        "name": "Input",
        "description": "data to add",
        "type": "file",
        "defaultValue": ""
      },
      {
        "name": "Lat Column",
        "description": "latitude column name",
        "type": "dropdown",
        "defaultValue": ""
      },
      {
        "name": "Long Column",
        "description": "longitude column name",
        "type": "dropdown",
        "defaultValue": ""
      },
      {
        "name": "Override Columns",
        "description": "manually specify columns",
        "type": "boolean",
        "defaultValue": false
      }
    ]
  },
  {
    "key": "BufferTool",
    "name": "Buffer",
    "description": "Makes a buffer around the input layer",
    "headlessSupported": false,
    "parameters": [
      {
        "name": "Input Layer",
        "description": "The input layer to buffer",
        "type": "dropdown",
        "defaultValue": ""
      },
      {
        "name": "Distance",
        "description": "The distance",
        "type": "float",
        "defaultValue": 10
      },
      {
        "name": "Units",
        "description": "The units for the distance",
        "type": "dropdown",
        "defaultValue": "miles",
        "options": [
          "feet",
          "miles",
          "kilometers",
          "degrees"
        ]
      }
    ]
  },
  {
    "key": "ExportTool",
    "name": "Export",
    "description": "Export data",
    "headlessSupported": false,
    "parameters": [
      {
        "name": "Layer",
        "description": "layer to export",
        "type": "dropdown",
        "defaultValue": ""
      },
      {
        "name": "Format",
        "description": "format to export",
        "type": "dropdown",
        "defaultValue": "geojson"
      }
    ]
  },
  {
    "key": "GenerateAIFeatures",
    "name": "Generate AI Features",
    "description": "",
    "headlessSupported": false,
    "parameters": [
      {
        "name": "Prompt",
        "description": "The prompt to generate AI features",
        "type": "text",
        "defaultValue": ""
      }
    ]
  },
  {
    "key": "GroupTool",
    "name": "Group",
    "description": "Groups nearby features by distance and adds the grouped result as a new layer",
    "headlessSupported": false,
    "parameters": [
      {
        "name": "Layer",
        "description": "layer to group",
        "type": "dropdown",
        "defaultValue": ""
      },
      {
        "name": "Distance",
        "description": "distance threshold",
        "type": "float",
        "defaultValue": 10,
        "min": 0
      },
      {
        "name": "Units",
        "description": "The units for the distance",
        "type": "dropdown",
        "defaultValue": "kilometers",
        "options": [
          "feet",
          "miles",
          "kilometers",
          "degrees"
        ]
      }
    ]
  },
  {
    "key": "RandomPointsTool",
    "name": "Random Points",
    "description": "Adds random points within selected polygon",
    "headlessSupported": false,
    "parameters": [
      {
        "name": "Points Count",
        "description": "Number of random points to generate.",
        "type": "int",
        "defaultValue": 10
      },
      {
        "name": "Inside Polygon",
        "description": "Generate points inside polygon",
        "type": "boolean",
        "defaultValue": false
      },
      {
        "name": "Polygon",
        "description": "Polygon to add random points within.",
        "type": "dropdown",
        "defaultValue": ""
      }
    ]
  },
  {
    "key": "AddAIGeneratedFieldTool",
    "name": "Add AI-Generated Field",
    "description": "Generate a new attribute field from existing feature attributes using AI",
    "headlessSupported": true,
    "parameters": [
      {
        "name": "Input Layer",
        "description": "The input layer to enrich",
        "type": "dropdown",
        "defaultValue": ""
      },
      {
        "name": "Source Fields",
        "description": "Comma-separated source fields to send to AI",
        "type": "text",
        "defaultValue": ""
      },
      {
        "name": "Instruction",
        "description": "The instruction used to generate the new field",
        "type": "text",
        "defaultValue": ""
      },
      {
        "name": "Output Field Name",
        "description": "The field to write",
        "type": "text",
        "defaultValue": ""
      },
      {
        "name": "Output Type",
        "description": "The output field type",
        "type": "dropdown",
        "defaultValue": "text",
        "options": [
          "text",
          "number",
          "boolean"
        ]
      },
      {
        "name": "Overwrite Existing Field",
        "description": "Overwrite existing values in the output field",
        "type": "boolean",
        "defaultValue": false
      }
    ]
  },
  {
    "key": "ConvertTextToNumericTool",
    "name": "Convert Text to Numeric",
    "description": "Convert text-like numeric attributes into numeric values",
    "headlessSupported": true,
    "parameters": [
      {
        "name": "Input Layer",
        "description": "The input layer to convert",
        "type": "dropdown",
        "defaultValue": ""
      },
      {
        "name": "Input Field Name",
        "description": "The text field to parse",
        "type": "text",
        "defaultValue": ""
      },
      {
        "name": "Output Field Name",
        "description": "The numeric field to write",
        "type": "text",
        "defaultValue": ""
      },
      {
        "name": "Overwrite Existing Field",
        "description": "Overwrite existing values in the output field",
        "type": "boolean",
        "defaultValue": false
      },
      {
        "name": "Use AI Fallback",
        "description": "Use AI when rules-based parsing fails",
        "type": "boolean",
        "defaultValue": true
      }
    ]
  }
]
